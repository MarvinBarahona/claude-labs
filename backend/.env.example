# Required — the backend fails fast at startup if this is missing.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — defaults to angular/angular if unset.
GITHUB_TARGET_REPO=angular/angular

# Optional — GitHub API calls run unauthenticated (lower rate limit) if unset.
GITHUB_TOKEN=ghp_your-token-here

# Optional — override the model tier → model ID mapping without a code change.
MODEL_DEFAULT=claude-sonnet-5
MODEL_CLASSIFICATION=claude-haiku-4-5
MODEL_HARDEST_CALL=claude-opus-4-8

# Optional — default output_config.effort for adaptive thinking. One of: low, medium, high, xhigh, max.
THINKING_EFFORT_DEFAULT=medium

# Optional — when true, every external client (Claude API and data sources) is bound to its
# fake implementation instead of the real one, so the app runs end to end with no outbound
# network call and no real credential. See docs/shared/fake-mode.md.
FAKE_MODE=false

# Optional — only used when FAKE_MODE=true. Shown as a link in the fake-mode banner pointing
# visitors to the real repo.
# REPO_URL=https://github.com/your-org/claude-labs
